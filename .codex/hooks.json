{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/restrict-to-harness-root.sh\"",
            "timeout": 30,
            "statusMessage": "Checking harness access policy"
          }
        ]
      },
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.codex/hooks/guard-writes-to-worktree.sh\"",
            "timeout": 30,
            "statusMessage": "Checking worktree write policy"
          }
        ]
      }
    ]
  }
}
